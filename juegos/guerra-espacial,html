<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Void Navigator - Space Combat</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #050505;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        #game-container {
            position: relative;
            box-shadow: 0 0 50px rgba(0, 150, 255, 0.2);
            border: 2px solid #333;
        }

        canvas {
            display: block;
            background-color: #000;
        }

        .ui-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.8);
            z-index: 10;
        }

        .hidden {
            display: none !important;
        }

        h1 {
            font-size: 48px;
            margin-bottom: 10px;
            color: #00d4ff;
            text-shadow: 0 0 20px #00d4ff;
            letter-spacing: 4px;
        }

        p {
            font-size: 18px;
            margin-bottom: 30px;
            color: #ccc;
        }

        button {
            padding: 15px 40px;
            font-size: 20px;
            background: transparent;
            color: #00d4ff;
            border: 2px solid #00d4ff;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 2px;
        }

        button:hover {
            background: #00d4ff;
            color: #000;
            box-shadow: 0 0 30px #00d4ff;
        }

        #hud {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            display: flex;
            justify-content: space-between;
            pointer-events: none;
            z-index: 5;
        }

        .stat-box {
            background: rgba(0, 0, 0, 0.5);
            padding: 10px 20px;
            border-left: 4px solid #00d4ff;
        }

        .health-bar-container {
            width: 200px;
            height: 15px;
            background: #333;
            margin-top: 5px;
            border-radius: 10px;
            overflow: hidden;
        }

        #health-fill {
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #ff4b2b, #ff416c);
            transition: width 0.3s;
        }

        #level-announcer {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 60px;
            color: #fff;
            text-shadow: 0 0 30px #00d4ff;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <!-- HUD -->
        <div id="hud" class="hidden">
            <div class="stat-box">
                <div>NIVEL: <span id="ui-level">1</span></div>
                <div class="health-bar-container">
                    <div id="health-fill"></div>
                </div>
            </div>
            <div class="stat-box" style="text-align: right;">
                <div>PUNTOS: <span id="ui-score">0</span></div>
                <div style="font-size: 12px; color: #00d4ff;">ARMA: <span id="ui-weapon">ESTÁNDAR</span></div>
            </div>
        </div>

        <div id="level-announcer">NIVEL 1</div>

        <!-- Pantalla de Inicio -->
        <div id="screen-start" class="ui-overlay">
            <h1>VOID NAVIGATOR</h1>
            <p>WASD/Flechas para mover | ESPACIO para disparar</p>
            <button onclick="startGame()">INICIAR MISIÓN</button>
        </div>

        <!-- Pantalla Game Over -->
        <div id="screen-gameover" class="ui-overlay hidden">
            <h1 style="color: #ff416c; text-shadow: 0 0 20px #ff416c;">MISIÓN FALLIDA</h1>
            <p>Tu nave ha sido destruida en el sector <span id="final-level">1</span>.</p>
            <p>Puntuación final: <span id="final-score">0</span></p>
            <button onclick="restartGame()">REINTENTAR</button>
        </div>

        <!-- Pantalla Victoria -->
        <div id="screen-victory" class="ui-overlay hidden">
            <h1>SISTEMA LIBERADO</h1>
            <p>Has completado todos los sectores con éxito.</p>
            <p>Puntuación total: <span id="victory-score">0</span></p>
            <button onclick="restartGame()">VOLVER A JUGAR</button>
        </div>

        <canvas id="gameCanvas"></canvas>
    </div>

<script>
    /**
     * CONFIGURACIÓN Y VARIABLES GLOBALES
     */
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const screenStart = document.getElementById('screen-start');
    const screenGameOver = document.getElementById('screen-gameover');
    const screenVictory = document.getElementById('screen-victory');
    const hud = document.getElementById('hud');
    
    // Ajuste de tamaño del canvas
    canvas.width = 1000;
    canvas.height = 700;

    let gameActive = false;
    let score = 0;
    let level = 1;
    let particles = [];
    let bullets = [];
    let enemyBullets = [];
    let enemies = [];
    let asteroids = [];
    let powerups = [];
    let stars = [];
    
    const keys = {};

    // Configuración de niveles
    const levelConfigs = [
        { asteroids: 5, enemies: 2, enemySpeed: 1, spawnRate: 0.005 },
        { asteroids: 8, enemies: 4, enemySpeed: 1.5, spawnRate: 0.008 },
        { asteroids: 12, enemies: 6, enemySpeed: 2.2, spawnRate: 0.012 }
    ];

    /**
     * AUDIO ENGINE (Sintético)
     */
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playSound(type) {
        if (!gameActive && type !== 'explosion') return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);

        const now = audioCtx.currentTime;

        if (type === 'laser') {
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(800, now);
            osc.frequency.exponentialRampToValueAtTime(40, now + 0.1);
            gain.gain.setValueAtTime(0.1, now);
            gain.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
            osc.start();
            osc.stop(now + 0.1);
        } else if (type === 'explosion') {
            osc.type = 'square';
            osc.frequency.setValueAtTime(100, now);
            osc.frequency.exponentialRampToValueAtTime(10, now + 0.3);
            gain.gain.setValueAtTime(0.3, now);
            gain.gain.linearRampToValueAtTime(0, now + 0.3);
            osc.start();
            osc.stop(now + 0.3);
        } else if (type === 'powerup') {
            osc.type = 'sine';
            osc.frequency.setValueAtTime(440, now);
            osc.frequency.exponentialRampToValueAtTime(880, now + 0.2);
            gain.gain.setValueAtTime(0.2, now);
            gain.gain.linearRampToValueAtTime(0, now + 0.2);
            osc.start();
            osc.stop(now + 0.2);
        }
    }

    /**
     * CLASES DEL JUEGO
     */

    class Player {
        constructor() {
            this.reset();
        }

        reset() {
            this.x = canvas.width / 2;
            this.y = canvas.height / 2;
            this.radius = 15;
            this.angle = -Math.PI / 2;
            this.velocity = { x: 0, y: 0 };
            this.friction = 0.98;
            this.acceleration = 0.15;
            this.rotationSpeed = 0.08;
            this.health = 100;
            this.maxHealth = 100;
            this.cooldown = 0;
            this.fireRate = 15;
            this.powerTimer = 0;
            this.isInvulnerable = false;
            this.invulnerableTimer = 0;
        }

        update() {
            // Controles de Rotación
            if (keys['KeyA'] || keys['ArrowLeft']) this.angle -= this.rotationSpeed;
            if (keys['KeyD'] || keys['ArrowRight']) this.angle += this.rotationSpeed;

            // Controles de Empuje
            if (keys['KeyW'] || keys['ArrowUp']) {
                this.velocity.x += Math.cos(this.angle) * this.acceleration;
                this.velocity.y += Math.sin(this.angle) * this.acceleration;
                
                // Partículas de motor
                if (Math.random() > 0.5) {
                    createParticles(
                        this.x - Math.cos(this.angle) * 15,
                        this.y - Math.sin(this.angle) * 15,
                        '#00d4ff', 2
                    );
                }
            }

            // Aplicar inercia y fricción
            this.x += this.velocity.x;
            this.y += this.velocity.y;
            this.velocity.x *= this.friction;
            this.velocity.y *= this.friction;

            // Límites del mapa (Bounce)
            if (this.x < 0) this.x = canvas.width;
            if (this.x > canvas.width) this.x = 0;
            if (this.y < 0) this.y = canvas.height;
            if (this.y > canvas.height) this.y = 0;

            // Disparo
            if (keys['Space'] && this.cooldown <= 0) {
                this.shoot();
            }
            if (this.cooldown > 0) this.cooldown--;

            // Power-up timer
            if (this.powerTimer > 0) {
                this.powerTimer--;
                if (this.powerTimer === 0) {
                    this.fireRate = 15;
                    document.getElementById('ui-weapon').innerText = "ESTÁNDAR";
                }
            }

            // Invulnerabilidad post-daño
            if (this.invulnerableTimer > 0) {
                this.invulnerableTimer--;
            }
        }

        shoot() {
            playSound('laser');
            bullets.push(new Bullet(
                this.x + Math.cos(this.angle) * 20,
                this.y + Math.sin(this.angle) * 20,
                this.angle,
                '#00d4ff'
            ));
            
            // Disparo triple si tiene powerup
            if (this.powerTimer > 0) {
                bullets.push(new Bullet(this.x, this.y, this.angle - 0.2, '#00ffaa'));
                bullets.push(new Bullet(this.x, this.y, this.angle + 0.2, '#00ffaa'));
            }

            this.cooldown = this.fireRate;
        }

        draw() {
            ctx.save();
            ctx.translate(this.x, this.y);
            ctx.rotate(this.angle);

            // Parpadeo si es invulnerable
            if (this.invulnerableTimer > 0 && Math.floor(Date.now() / 100) % 2 === 0) {
                ctx.globalAlpha = 0.3;
            }

            // Cuerpo de la nave
            ctx.beginPath();
            ctx.moveTo(20, 0);
            ctx.lineTo(-15, -15);
            ctx.lineTo(-10, 0);
            ctx.lineTo(-15, 15);
            ctx.closePath();
            
            ctx.strokeStyle = '#00d4ff';
            ctx.lineWidth = 2;
            ctx.stroke();
            ctx.fillStyle = '#003344';
            ctx.fill();

            // Cabina
            ctx.beginPath();
            ctx.arc(0, 0, 5, 0, Math.PI * 2);
            ctx.fillStyle = '#fff';
            ctx.fill();

            ctx.restore();
        }

        takeDamage(amount) {
            if (this.invulnerableTimer > 0) return;
            
            this.health -= amount;
            this.invulnerableTimer = 60; // 1 segundo
            createParticles(this.x, this.y, '#ff0000', 15);
            playSound('explosion');

            if (this.health <= 0) {
                this.health = 0;
                gameOver();
            }
            updateHUD();
        }
    }

    class Bullet {
        constructor(x, y, angle, color) {
            this.x = x;
            this.y = y;
            this.speed = 10;
            this.vx = Math.cos(angle) * this.speed;
            this.vy = Math.sin(angle) * this.speed;
            this.radius = 3;
            this.color = color;
            this.life = 100;
        }

        update() {
            this.x += this.vx;
            this.y += this.vy;
            this.life--;
        }

        draw() {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
            ctx.fillStyle = this.color;
            ctx.shadowBlur = 10;
            ctx.shadowColor = this.color;
            ctx.fill();
            ctx.shadowBlur = 0;
        }
    }

    class Asteroid {
        constructor(isSmall = false, x, y) {
            this.x = x || Math.random() * canvas.width;
            this.y = y || Math.random() * canvas.height;
            this.radius = isSmall ? 15 : 30 + Math.random() * 20;
            this.isSmall = isSmall;
            this.vx = (Math.random() - 0.5) * 2;
            this.vy = (Math.random() - 0.5) * 2;
            this.points = [];
            const segments = 8;
            for(let i=0; i<segments; i++) {
                const angle = (i / segments) * Math.PI * 2;
                const dist = this.radius * (0.8 + Math.random() * 0.4);
                this.points.push({
                    x: Math.cos(angle) * dist,
                    y: Math.sin(angle) * dist
                });
            }
        }

        update() {
            this.x += this.vx;
            this.y += this.vy;

            if (this.x < -50) this.x = canvas.width + 50;
            if (this.x > canvas.width + 50) this.x = -50;
            if (this.y < -50) this.y = canvas.height + 50;
            if (this.y > canvas.height + 50) this.y = -50;
        }

        draw() {
            ctx.save();
            ctx.translate(this.x, this.y);
            ctx.beginPath();
            ctx.moveTo(this.points[0].x, this.points[0].y);
            for(let i=1; i<this.points.length; i++) {
                ctx.lineTo(this.points[i].x, this.points[i].y);
            }
            ctx.closePath();
            ctx.strokeStyle = '#888';
            ctx.lineWidth = 2;
            ctx.stroke();
            ctx.fillStyle = '#222';
            ctx.fill();
            ctx.restore();
        }
    }

    class Enemy {
        constructor() {
            // Aparecer fuera de pantalla
            const side = Math.floor(Math.random() * 4);
            if (side === 0) { this.x = -30; this.y = Math.random() * canvas.height; }
            else if (side === 1) { this.x = canvas.width + 30; this.y = Math.random() * canvas.height; }
            else if (side === 2) { this.x = Math.random() * canvas.width; this.y = -30; }
            else { this.x = Math.random() * canvas.width; this.y = canvas.height + 30; }

            this.radius = 18;
            this.speed = levelConfigs[level-1].enemySpeed;
            this.health = 2;
            this.cooldown = 100 + Math.random() * 100;
        }

        update() {
            // Perseguir al jugador
            const dx = player.x - this.x;
            const dy = player.y - this.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            const angle = Math.atan2(dy, dx);

            this.x += Math.cos(angle) * this.speed;
            this.y += Math.sin(angle) * this.speed;

            // Disparar
            this.cooldown--;
            if (this.cooldown <= 0 && dist < 400) {
                enemyBullets.push(new Bullet(this.x, this.y, angle, '#ff416c'));
                this.cooldown = 120;
            }
        }

        draw() {
            ctx.save();
            ctx.translate(this.x, this.y);
            const angle = Math.atan2(player.y - this.y, player.x - this.x);
            ctx.rotate(angle);

            // Cuerpo enemigo (Triángulo invertido agresivo)
            ctx.beginPath();
            ctx.moveTo(18, 0);
            ctx.lineTo(-12, -12);
            ctx.lineTo(-12, 12);
            ctx.closePath();
            ctx.strokeStyle = '#ff416c';
            ctx.lineWidth = 2;
            ctx.stroke();
            ctx.fillStyle = '#440011';
            ctx.fill();
            
            ctx.restore();
        }
    }

    class PowerUp {
        constructor(x, y) {
            this.x = x;
            this.y = y;
            this.radius = 12;
            this.type = Math.random() > 0.5 ? 'health' : 'weapon';
            this.pulse = 0;
        }

        update() {
            this.pulse += 0.1;
        }

        draw() {
            const s = 1 + Math.sin(this.pulse) * 0.2;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius * s, 0, Math.PI * 2);
            ctx.strokeStyle = this.type === 'health' ? '#00ff44' : '#ffaa00';
            ctx.lineWidth = 2;
            ctx.stroke();
            
            ctx.fillStyle = this.type === 'health' ? '#00ff44' : '#ffaa00';
            ctx.font = "bold 14px Arial";
            ctx.textAlign = "center";
            ctx.fillText(this.type === 'health' ? "H" : "W", this.x, this.y + 5);
        }
    }

    /**
     * SISTEMA DE PARTÍCULAS
     */
    function createParticles(x, y, color, count) {
        for(let i=0; i<count; i++) {
            particles.push({
                x: x,
                y: y,
                vx: (Math.random() - 0.5) * 5,
                vy: (Math.random() - 0.5) * 5,
                life: 30 + Math.random() * 20,
                color: color,
                size: 1 + Math.random() * 3
            });
        }
    }

    function updateParticles() {
        for(let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.x += p.vx;
            p.y += p.vy;
            p.life--;
            if (p.life <= 0) particles.splice(i, 1);
        }
    }

    function drawParticles() {
        particles.forEach(p => {
            ctx.globalAlpha = p.life / 50;
            ctx.fillStyle = p.color;
            ctx.fillRect(p.x, p.y, p.size, p.size);
        });
        ctx.globalAlpha = 1;
    }

    /**
     * CONTROLADORES DE JUEGO
     */
    const player = new Player();

    function startGame() {
        if (audioCtx.state === 'suspended') audioCtx.resume();
        gameActive = true;
        score = 0;
        level = 1;
        player.reset();
        initLevel(level);
        
        screenStart.classList.add('hidden');
        screenGameOver.classList.add('hidden');
        screenVictory.classList.add('hidden');
        hud.classList.remove('hidden');
        
        requestAnimationFrame(gameLoop);
    }

    function restartGame() {
        bullets = [];
        enemyBullets = [];
        enemies = [];
        asteroids = [];
        particles = [];
        powerups = [];
        startGame();
    }

    function initLevel(l) {
        asteroids = [];
        enemies = [];
        bullets = [];
        enemyBullets = [];
        
        const config = levelConfigs[l-1];
        for(let i=0; i<config.asteroids; i++) {
            asteroids.push(new Asteroid());
        }

        // Announcer
        const ann = document.getElementById('level-announcer');
        ann.innerText = `SECTOR ${l}`;
        ann.style.opacity = 1;
        setTimeout(() => ann.style.opacity = 0, 2000);
        
        updateHUD();
    }

    function nextLevel() {
        level++;
        if (level > levelConfigs.length) {
            victory();
        } else {
            initLevel(level);
        }
    }

    function gameOver() {
        gameActive = false;
        playSound('explosion');
        document.getElementById('final-score').innerText = score;
        document.getElementById('final-level').innerText = level;
        screenGameOver.classList.remove('hidden');
        hud.classList.add('hidden');
    }

    function victory() {
        gameActive = false;
        document.getElementById('victory-score').innerText = score;
        screenVictory.classList.remove('hidden');
        hud.classList.add('hidden');
    }

    function updateHUD() {
        document.getElementById('ui-level').innerText = level;
        document.getElementById('ui-score').innerText = score;
        document.getElementById('health-fill').style.width = `${(player.health / player.maxHealth) * 100}%`;
    }

    // Estrellas de fondo estáticas
    for(let i=0; i<150; i++) {
        stars.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            size: Math.random() * 2,
            opacity: Math.random()
        });
    }

    /**
     * BUCLE PRINCIPAL
     */
    function gameLoop() {
        if (!gameActive) return;

        // Limpiar canvas
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Dibujar Fondo
        stars.forEach(s => {
            ctx.fillStyle = `rgba(255, 255, 255, ${s.opacity})`;
            ctx.fillRect(s.x, s.y, s.size, s.size);
        });

        // Generación espontánea de enemigos
        if (Math.random() < levelConfigs[level-1].spawnRate && enemies.length < levelConfigs[level-1].enemies) {
            enemies.push(new Enemy());
        }

        // 1. Actualizar Jugador
        player.update();
        player.draw();

        // 2. Proyectiles Jugador
        for(let i=bullets.length-1; i>=0; i--) {
            bullets[i].update();
            bullets[i].draw();
            if (bullets[i].life <= 0) bullets.splice(i, 1);
        }

        // 3. Proyectiles Enemigos
        for(let i=enemyBullets.length-1; i>=0; i--) {
            const b = enemyBullets[i];
            b.update();
            b.draw();
            
            // Colisión con jugador
            const dist = Math.hypot(player.x - b.x, player.y - b.y);
            if (dist < player.radius + b.radius) {
                player.takeDamage(10);
                enemyBullets.splice(i, 1);
                continue;
            }
            if (b.life <= 0) enemyBullets.splice(i, 1);
        }

        // 4. Asteroides
        for(let i=asteroids.length-1; i>=0; i--) {
            const a = asteroids[i];
            a.update();
            a.draw();

            // Colisión con jugador
            const distP = Math.hypot(player.x - a.x, player.y - a.y);
            if (distP < player.radius + a.radius) {
                player.takeDamage(20);
                // Empuje
                player.velocity.x *= -1.5;
                player.velocity.y *= -1.5;
            }

            // Colisión con balas
            for(let j=bullets.length-1; j>=0; j--) {
                const b = bullets[j];
                const distB = Math.hypot(a.x - b.x, a.y - b.y);
                if (distB < a.radius + b.radius) {
                    playSound('explosion');
                    createParticles(a.x, a.y, '#888', 10);
                    
                    // Dividir si es grande
                    if (!a.isSmall) {
                        asteroids.push(new Asteroid(true, a.x, a.y));
                        asteroids.push(new Asteroid(true, a.x, a.y));
                    }
                    
                    asteroids.splice(i, 1);
                    bullets.splice(j, 1);
                    score += 50;
                    updateHUD();
                    break;
                }
            }
        }

        // 5. Enemigos
        for(let i=enemies.length-1; i>=0; i--) {
            const e = enemies[i];
            e.update();
            e.draw();

            // Colisión con jugador (choque directo)
            const distP = Math.hypot(player.x - e.x, player.y - e.y);
            if (distP < player.radius + e.radius) {
                player.takeDamage(30);
                createParticles(e.x, e.y, '#ff416c', 20);
                enemies.splice(i, 1);
                continue;
            }

            // Colisión con balas jugador
            for(let j=bullets.length-1; j>=0; j--) {
                const b = bullets[j];
                const distB = Math.hypot(e.x - b.x, e.y - b.y);
                if (distB < e.radius + b.radius) {
                    e.health--;
                    bullets.splice(j, 1);
                    createParticles(e.x, e.y, '#ff416c', 5);
                    
                    if (e.health <= 0) {
                        playSound('explosion');
                        createParticles(e.x, e.y, '#ff416c', 20);
                        
                        // Posibilidad de powerup
                        if (Math.random() < 0.3) powerups.push(new PowerUp(e.x, e.y));
                        
                        enemies.splice(i, 1);
                        score += 200;
                        updateHUD();
                    }
                    break;
                }
            }
        }

        // 6. Power Ups
        for(let i=powerups.length-1; i>=0; i--) {
            const p = powerups[i];
            p.update();
            p.draw();
            
            const dist = Math.hypot(player.x - p.x, player.y - p.y);
            if (dist < player.radius + p.radius) {
                playSound('powerup');
                if (p.type === 'health') {
                    player.health = Math.min(player.maxHealth, player.health + 30);
                } else {
                    player.powerTimer = 600; // 10 segundos
                    player.fireRate = 8;
                    document.getElementById('ui-weapon').innerText = "TRIPLE RAPID";
                }
                powerups.splice(i, 1);
                updateHUD();
            }
        }

        // 7. Partículas
        updateParticles();
        drawParticles();

        // Condición de victoria de nivel (Limpiar asteroides y enemigos iniciales)
        if (asteroids.length === 0 && enemies.length === 0) {
            nextLevel();
        }

        requestAnimationFrame(gameLoop);
    }

    /**
     * INPUT LISTENERS
     */
    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);

</script>
</body>
</html>
